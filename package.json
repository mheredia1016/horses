{
  "name": "horse-racing-discord-bot",
  "version": "1.0.0",
  "description": "Free-source horse racing Discord alerts: win bets, longshots, exactas, and selective superfecta boxes.",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "test-alert": "DRY_RUN=true node src/test-alert.js",
